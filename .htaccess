# ============================================================
# Mitzy Travel and Tours - Optimized Clean URL + Backend Fix
# ============================================================

<IfModule mod_rewrite.c>
RewriteEngine On

# ------------------------------------------------------------
# 0️⃣ EXCLUDE: Allow backend, admin, and assets folders
# ------------------------------------------------------------
# Prevent rewrite interference with backend panels, admin login, and static files
RewriteCond %{REQUEST_URI} ^/backend/ [NC,OR]
RewriteCond %{REQUEST_URI} ^/admin [NC,OR]
RewriteCond %{REQUEST_URI} ^/assets/ [NC]
RewriteRule ^ - [L]

# ------------------------------------------------------------
# 1️⃣ Remove .php extensions from URLs (frontend only)
# ------------------------------------------------------------
# Redirect example.php → /example (clean URL for public pages)
RewriteCond %{THE_REQUEST} \s/([^.]+)\.php[\s?] [NC]
RewriteCond %{REQUEST_URI} !^/backend/ [NC]
RewriteCond %{REQUEST_URI} !^/admin [NC]
RewriteCond %{REQUEST_URI} !^/assets/ [NC]
RewriteRule ^ %1 [R=301,L,NC]

# Internally rewrite /example → example.php
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteCond %{REQUEST_URI} !^/backend/ [NC]
RewriteCond %{REQUEST_URI} !^/admin [NC]
RewriteCond %{REQUEST_URI} !^/assets/ [NC]
RewriteRule ^([^/]+)/?$ $1.php [L]

# ------------------------------------------------------------
# 2️⃣ Clean URL for tour pages
# ------------------------------------------------------------
# /tour/example_name → tourinfo.php?id=example_name
RewriteRule ^tour/([^/]+)/?$ tourinfo.php?id=$1 [L,QSA]

# ------------------------------------------------------------
# 3️⃣ Redirect old /tourinfo.php?id=example_name → /tour/example_name
# ------------------------------------------------------------
RewriteCond %{THE_REQUEST} \s/tourinfo\.php\?id=([^&\s]+) [NC,OR]
RewriteCond %{THE_REQUEST} \s/tourinfo\?id=([^&\s]+) [NC]
RewriteRule ^ /tour/%1? [R=301,L,NE]

# ------------------------------------------------------------
# 4️⃣ Force HTTPS (uncomment if SSL fully active)
# ------------------------------------------------------------
# RewriteCond %{HTTPS} !=on
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ------------------------------------------------------------
# 5️⃣ Default Directory Index
# ------------------------------------------------------------
DirectoryIndex index.php index.html
</IfModule>

# ============================================================
# 6️⃣ Security Headers (Recommended)
# ============================================================
<IfModule mod_headers.c>
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# ============================================================
# 7️⃣ Deny access to sensitive files
# ============================================================
<FilesMatch "\.(htaccess|env|git|sql|bak|ini|log)$">
Require all denied
</FilesMatch>
